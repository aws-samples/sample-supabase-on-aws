# ============================================
# Tenant Manager Service Configuration
# ============================================

# Service configuration
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Authentication
# Admin API key for authenticating management API requests
ADMIN_API_KEY=your-admin-api-key-here
# JWT secret used for signing project tokens
JWT_SECRET=your-jwt-secret-here

# Encryption key for storing secrets (AES-256-CBC)
# Must be at least 32 characters
ENCRYPTION_KEY=your-encryption-key-at-least-32-chars

# ============================================
# Database (direct PostgreSQL connection)
# ============================================
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_USER_READ_WRITE=supabase_admin
POSTGRES_USER_READ_ONLY=supabase_read_only_user

# Connection pool sizes
MANAGEMENT_DB_POOL_SIZE=10
SYSTEM_DB_POOL_SIZE=5

# ============================================
# External Services
# ============================================

# GoTrue (Auth)
GOTRUE_URL=http://auth:9999
GOTRUE_ADMIN_KEY=
GOTRUE_MULTI_TENANT=false

# Realtime
REALTIME_URL=http://realtime:4000

# Supavisor (Connection pooler)
SUPAVISOR_URL=http://supavisor:4000
SUPAVISOR_API_KEY=

# API JWT Secret (optional, for external service registration)
API_JWT_SECRET=

# Pooler configuration
POOLER_DEFAULT_POOL_SIZE=15
POOLER_MAX_CLIENT_CONN=200

# Site URL (for Auth service redirects)
SITE_URL=http://localhost:3000
