{
  "name": "tenant-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Multi-tenant project management service for self-hosted Supabase",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "build:check": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "migrate:up": "tsx scripts/migrate.ts up",
    "migrate:down": "tsx scripts/migrate.ts down"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.989.0",
    "@aws-sdk/client-secrets-manager": "^3.986.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "dotenv": "^17.2.3",
    "fastify": "^4.26.2",
    "jsonwebtoken": "^9.0.2",
    "kysely": "^0.27.5",
    "pg": "^8.13.1",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.12.0",
    "@types/pg": "^8.11.11",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
