# AWS Configuration (automatically detected by CDK)
# CDK_DEFAULT_ACCOUNT - automatically set by CDK from AWS credentials
# CDK_DEFAULT_REGION - automatically set by CDK from AWS config, defaults to us-east-1

# VPC Configuration
VPC_ID=<VPC_ID>
SUBNET_IDS=<SUBNET_ID_1>,<SUBNET_ID_2>
SECURITY_GROUP_ID=<SECURITY_GROUP_ID>
KONG_SECURITY_GROUP_ID=<KONG_SECURITY_GROUP_ID>

# ECS Configuration
CLUSTER_NAME=<CLUSTER_NAME>
TASK_ROLE_ARN=<TASK_ROLE_ARN>
EXECUTION_ROLE_ARN=<EXECUTION_ROLE_ARN>
LOG_GROUP_NAME=/ecs/supabase

# Container Configuration
CONTAINER_IMAGE=supabase/edge-runtime:v1.69.28

# Service Discovery
SERVICE_DISCOVERY_ID=<SERVICE_DISCOVERY_ID>
